# Maintainer: LitheDB Contributors <contact@lithedb.dev>
pkgname=lithedb-qt
pkgver=0.1.2
pkgrel=1
pkgdesc="Qt6 desktop database client powered by a shared Rust core"
arch=('x86_64')
url="https://github.com/tuansaker1412/lithedb"
license=('MIT')
depends=('qt6-base' 'hicolor-icon-theme')
makedepends=('cargo' 'cmake' 'gcc' 'git' 'ninja' 'rust')
source=()
sha256sums=()

_repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
_build_dir="$_repo_root/apps/lithedb-qt/build-arch"

build() {
    cd "$_repo_root"
    cargo build -p lithedb-bridge --release --locked
    cmake -S apps/lithedb-qt -B "$_build_dir" -G Ninja -DCMAKE_BUILD_TYPE=Release
    cmake --build "$_build_dir"
}

package() {
    cd "$_repo_root"
    DESTDIR="$pkgdir" cmake --install "$_build_dir" --prefix /usr --strip
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
