# Maintainer: Table Pro Linux <contact@tableprolinux.org>
pkgname=table-pro-linux
pkgver=0.1.2
pkgrel=1
pkgdesc="A modern, native Linux database client built with Rust, GTK4, and libadwaita"
arch=('x86_64')
url="https://github.com/tuansaker1412/table-pro-linux"
license=('MIT')
depends=('gtk4' 'libadwaita' 'gtksourceview5' 'sqlite')
makedepends=('rust' 'cargo')
source=()
sha256sums=()

build() {
    cd "$srcdir/../../../"
    export CC=gcc
    export CXX=g++
    export AR=ar
    export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=gcc
    cargo build --release --locked
}

package() {
    cd "$srcdir/../../../"
    
    # Install binary
    install -Dm755 "target/release/table-pro-linux" "$pkgdir/usr/bin/table-pro-linux"
    
    # Install desktop file
    install -Dm644 "packaging/flatpak/org.tableprolinux.App.desktop" \
        "$pkgdir/usr/share/applications/org.tableprolinux.App.desktop"
    
    # Install icon
    install -Dm644 "packaging/flatpak/org.tableprolinux.App.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/org.tableprolinux.App.svg"
    
    # Install metainfo
    install -Dm644 "packaging/flatpak/org.tableprolinux.App.metainfo.xml" \
        "$pkgdir/usr/share/metainfo/org.tableprolinux.App.metainfo.xml"
    
    # Install documentation
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
