# Maintainer: LitheDB Contributors <contact@lithedb.dev>
pkgname=lithedb
pkgver=0.1.2
pkgrel=1
pkgdesc="LitheDB is a lightweight native database client for Linux built with Rust, GTK4, and libadwaita"
arch=('x86_64')
url="https://github.com/tuansaker1412/lithedb"
license=('MIT')
depends=('gtk4' 'libadwaita' 'gtksourceview5' 'sqlite')
makedepends=('rust' 'cargo')
source=()
sha256sums=()

build() {
    cd "$srcdir/../../../"
    export CC=gcc
    export CXX=g++
    export AR=ar
    export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER=gcc
    cargo build --release --locked
}

package() {
    cd "$srcdir/../../../"
    
    # Install binary
    install -Dm755 "target/release/lithedb" "$pkgdir/usr/bin/lithedb"
    
    # Install desktop file
    install -Dm644 "packaging/flatpak/io.github.tuansaker1412.LitheDB.desktop" \
        "$pkgdir/usr/share/applications/io.github.tuansaker1412.LitheDB.desktop"
    
    # Install icon
    install -Dm644 "packaging/flatpak/io.github.tuansaker1412.LitheDB.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/io.github.tuansaker1412.LitheDB.svg"
    
    # Install metainfo
    install -Dm644 "packaging/flatpak/io.github.tuansaker1412.LitheDB.metainfo.xml" \
        "$pkgdir/usr/share/metainfo/io.github.tuansaker1412.LitheDB.metainfo.xml"
    
    # Install documentation
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
